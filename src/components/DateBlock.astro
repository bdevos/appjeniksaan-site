---
import type { CollectionEntry } from 'astro:content'
import { dateFormatter } from '../utils/dateFormat'

interface Props {
  item: CollectionEntry<'linked'> | CollectionEntry<'posts'>
}

const { item } = Astro.props
---

<time datetime={item.data.pubDate} class="flex">
  <a
    href={`/${item.collection}/${item.id}`}
    class="hover:text-sky-900 dark:hover:text-sky-500"
  >
    {dateFormatter.format(new Date(item.data.pubDate))}
  </a>
</time>
