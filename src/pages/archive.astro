---
import { getCollection } from 'astro:content'
import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts'
import { sortAndLimit, splitPostByMonth } from '../utils/sortAndLimit'
import { dayFormatter, formatMonth } from '../utils/dateFormat'
const linked = getCollection('linked')
const posts = getCollection('posts')

const items = splitPostByMonth(sortAndLimit(await linked, await posts))

const formatDay = (pubDate: string) => dayFormatter.format(new Date(pubDate))
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1 class="mt-8 text-3xl text-mist-700 lg:text-4xl dark:text-mist-300">
        Archive
      </h1>
      {
        Object.keys(items).map((month) => (
          <section class="my-8">
            <h2 class="font-display mb-6 text-lg text-mist-600 uppercase dark:text-mist-400">
              {formatMonth(month)}
            </h2>
            <ul class="grid grid-cols-[auto_1fr]">
              {items[month].map((item) => (
                <li class="col-span-full my-2 grid grid-cols-subgrid gap-4">
                  <div class="font-display self-baseline text-xl leading-8 font-light text-mist-500 lg:text-xl lg:leading-10">
                    {formatDay(item.data.pubDate)}
                  </div>
                  <h3 class="text-2xl text-pretty text-sky-700 lg:text-3xl dark:text-sky-300">
                    <a
                      href={`/${item.collection}/${item.id}`}
                      class="hover:text-sky-950 dark:hover:text-sky-100"
                    >
                      {item.data.title}
                    </a>
                  </h3>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </main>
    <Footer />
  </body>
</html>
