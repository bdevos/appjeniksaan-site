---
import { getCollection } from 'astro:content'
import BaseHead from '../../components/BaseHead.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts'
import { splitReadingByMonth } from '../../utils/splitReadingByMonth'
import { dayFormatter, formatMonth } from '../../utils/dateFormat'

const items = splitReadingByMonth(await getCollection('reading'))
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1
        class="mt-8 mb-4 text-3xl text-mist-700 lg:text-4xl dark:text-mist-200"
      >
        Reading Activity
      </h1>
      <p>
        Since August 2023, I have been documenting my reading activity. Below
        are the books I have completed.
      </p>
      {
        Object.keys(items).map((month) => (
          <section class="my-8">
            <h2 class="font-display mb-6 text-lg text-mist-700 uppercase dark:text-mist-400">
              {formatMonth(month)}
            </h2>
            <ul class="grid grid-cols-[auto_1fr]">
              {items[month].map((book) => (
                <li class="col-span-full my-2 grid grid-cols-subgrid gap-4">
                  <div class="font-display justify-self-center text-xl leading-10 font-light text-mist-500 md:text-2xl">
                    {dayFormatter.format(book.data.completed)}
                  </div>
                  <h3 class="font-display text-2xl leading-10 uppercase md:text-4xl">
                    <a href={`/${book.collection}/${book.id}`}>
                      {book.data.title}
                    </a>
                  </h3>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </main>
    <Footer />
  </body>
</html>
